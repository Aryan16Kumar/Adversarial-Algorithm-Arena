# Supabase (Person 2's database) — copy this file to ".env" and fill in your
# project's values. The .env file is gitignored, so secrets stay out of git.
# Find these in the Supabase dashboard → Project Settings → API.
#
#   VITE_SUPABASE_URL       = your project URL (https://xxxx.supabase.co)
#   VITE_SUPABASE_ANON_KEY  = the "anon" public key (safe for the browser;
#                             protect tables with Row-Level Security policies)
#
# After setting these, restart `npm run dev`. Without them, the game still runs
# but the leaderboard submit is skipped (a console warning is logged).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
